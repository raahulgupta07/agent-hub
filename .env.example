# Super-admin credentials for the /admin console. Change these.
ADMIN_EMAIL=admin@city.gov
ADMIN_PASSWORD=change-me-please

# Secret used to sign session cookies. Use a long random string.
# Generate one:  openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-string

# Where the JSON config store is written (Docker points this at the volume).
DATA_FILE=/data/data.json

# Max request body (config PUTs include logo data-URLs). 10 MB.
BODY_SIZE_LIMIT=10485760

# --- Behind a TLS reverse proxy (e.g. Nginx Proxy Manager) ---
# Let the app detect real https/host/client-IP from proxy headers so Secure
# cookies are set and login rate-limiting sees the real IP.
PROTOCOL_HEADER=x-forwarded-proto
HOST_HEADER=x-forwarded-host
# ADDRESS_HEADER: ONLY enable if your proxy actually sends X-Forwarded-For.
# If set but the header is absent on a request, adapter-node throws (500).
# Leave commented for direct access.
# ADDRESS_HEADER=x-forwarded-for
# Optionally pin the public origin instead of the headers above:
# ORIGIN=https://hub.example.com
