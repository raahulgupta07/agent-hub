# Super-admin credentials for the /admin console. Change these.
ADMIN_EMAIL=admin@city.gov
ADMIN_PASSWORD=change-me-please

# Secret used to sign session cookies. Use a long random string.
# Generate one:  openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-string

# Where the JSON config store is written (Docker points this at the volume).
DATA_FILE=/data/data.json
